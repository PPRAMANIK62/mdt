      <li>
        <a href="https://github.com/PPRAMANIK62/mdt" target="_blank" rel="noopener noreferrer">
          View on GitHub
        </a>
      </li>
      <li>
        <a href={`${import.meta.env.BASE_URL}getting-started/`}>Documentation</a>
